# Copy to .env and fill in real values. Do not commit .env.

# Database (async driver for app)
DATABASE_URL=postgresql+asyncpg://postgres:RHzAVJqIZxmkkmaGDKPLkJLvbsyqmGqK@postgres.railway.internal:5432/railway

# Scheduler job store (sync driver)
SCHEDULER_JOBSTORE_URL=postgresql+psycopg2://user:password@localhost:5432/collective

# Telegram Bot
TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather
TELEGRAM_WEBHOOK_PATH=/telegram/webhook/your_secret_path
TELEGRAM_SECRET_TOKEN=
WEBHOOK_BASE_URL=https://your-domain.com

# Admin JWT
JWT_SECRET=your_long_random_jwt_secret
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=

# Generate password hash: python -c "import passlib.hash; print(passlib.hash.bcrypt.hash('your_password'))"

# Optional: admin Telegram notifications
# ADMIN_TELEGRAM_CHAT_ID=

# Optional: rate limit for admin API (requests per minute)
# ADMIN_RATE_LIMIT_PER_MINUTE=60

# Optional: app name, environment, log level
# APP_NAME=collective-bot
# ENVIRONMENT=production
# LOG_LEVEL=INFO
